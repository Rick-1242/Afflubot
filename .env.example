# ==========================================
# Core Configuration (Required for ALL modes)
# ==========================================
# Copy this file to a new file named '.env' in the ROOT of the project.
#
# ⚠️ IMPORTANT: When running the Python scripts manually, your terminal's
# working directory MUST be the 'src' folder (i.e. run `cd src` first).
#
# Fill in your actual credentials below:

# --- Email / IMAP Settings ---
# Note: This example assumes a Gmail account, but any IMAP provider works.
IMAP_SERVER=imap.gmail.com
EMAIL_ADDRESS=your.email@gmail.com

# IMPORTANT: If using Gmail, you MUST use an "App Password", not your normal Google password.
# 1. Go to Google Account -> Security -> 2-Step Verification (Must be enabled)
# 2. Search for "App passwords" in your Google Account
# 3. Create a new App Password (e.g., name it "Afflubot")
# 4. Paste the 16-character password below (no spaces)
EMAIL_PASSWORD=your-16-char-app-password


# ==========================================
# Automated Scheduler Configuration
# (Required ONLY if using Docker / scheduler.py)
# ==========================================

# --- Booking Details ---
LIBRARY=Meneghetti
SPOT=141
TIME_START=09:00
TIME_END=18:00

# --- Scheduler Behavior ---
# Optional: The time of day the bot will run to make the booking (Default: 04:00)
# SCHEDULE_TIME=04:00

# Optional: Set to true to make the bot run immediately upon container startup
# instead of waiting for the next scheduled time.
RUN_ON_STARTUP=true
